# Copy this file to fastlane/.env and fill in your values.
# fastlane/.env is gitignored and must never be committed.

# Apple
APPLE_ID=you@example.com
APPLE_TEAM_ID=XXXXXXXXXX
APP_IDENTIFIER=com.yourname.appname

# App Store Connect API Key
# Download the .p8 from App Store Connect → Users & Access → Integrations → API Keys
APP_STORE_CONNECT_API_KEY_KEY_ID=XXXXXXXXXX
APP_STORE_CONNECT_API_KEY_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
APP_STORE_CONNECT_API_KEY_KEY_FILEPATH=~/.fastlane/api_keys/AuthKey_XXXXXXXXXX.p8

# Match (certificates repo)
MATCH_GIT_URL=git@github.com:yourname/your-certs-repo.git

# Android keystore (file lives at ~/.fastlane/api_keys/ — copied automatically by the lane)
ANDROID_KEYSTORE_PATH=android/400scorekeeper.keystore
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEYSTORE_ALIAS=
ANDROID_KEY_PASSWORD=

# Google Play service account JSON
SUPPLY_JSON_KEY=~/.fastlane/api_keys/play-store-key.json
